# Copy to .env and fill in your credentials.
#
# RECOMMENDED — Vite dev proxy (bypasses browser CORS):
#   VITE_COPILOT_MODE=proxy
#   VITE_COPILOT_PROXY_URL=/hai
#   VITE_COPILOT_UPSTREAM=http://localhost:6655/anthropic   # SAP Local Hai Proxy
#   VITE_ANTHROPIC_API_KEY=<your proxy auth token>
# The upstream + key are read by vite.config.js at dev-server startup, so the
# browser never needs to talk to the SAP proxy directly (which rejects CORS).
#
# Direct Anthropic API (sample data only — key is exposed in the browser):
#   VITE_COPILOT_MODE=direct
#   VITE_ANTHROPIC_API_KEY=sk-ant-...
VITE_COPILOT_MODE=proxy
VITE_COPILOT_PROXY_URL=/hai
VITE_COPILOT_UPSTREAM=http://localhost:6655/anthropic
VITE_ANTHROPIC_API_KEY=
